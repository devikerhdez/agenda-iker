# ─── Frontend Environment Variables ──────────────────────────────
# Copia este archivo como .env y rellena los valores reales

# URL base de la API del backend (incluye /api al final)
# En LOCAL: dejar vacío o no crear esta variable. El código usa http://localhost:8080/api por defecto.
# En PRODUCCIÓN (Docker): se inyecta como build arg en docker-compose.yml
VITE_API_URL=""

# VAPID Public Key (debe coincidir con la del Backend)
VITE_VAPID_PUBLIC_KEY=""
