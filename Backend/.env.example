# ─── Backend Environment Variables ───────────────────────────────
# Copia este archivo como .env y rellena los valores reales

# PostgreSQL (NeonDB)
DATABASE_URL="postgresql://usuario:password@host/dbname?sslmode=require"

# Puerto del servidor Go
PORT=8080

# CORS: dominios permitidos (separados por comas, sin espacios)
# Ejemplo en producción: https://agenda.tudominio.com,https://www.agenda.tudominio.com
# En local: dejar vacío (el backend usa localhost:5173 por defecto)
ALLOWED_ORIGINS=""

# Email para notificaciones (Gmail SMTP)
EMAIL_USER="tu@gmail.com"
EMAIL_PASS="tu_app_password"

# VAPID Keys para Web Push Notifications
# Genéralas con: go run ./scripts/gen_vapid/main.go
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
